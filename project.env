PROJECT_NAME=caverns-of-mars
VERSION=0.0.1

# usage: shrinko8.py [-h] [-f FORMAT] [-F INPUT_FORMAT] [-i] [-u] [-m] [-M] [--minify-consts-only] [-ot] [-oc] [-ob] [--no-minify-rename] [--no-minify-consts] [--no-minify-spaces]
#                   [--no-minify-lines] [--no-minify-comments] [--no-minify-tokens] [--no-minify-reorder] [-p PRESERVE] [--no-preserve NO_PRESERVE] [--rename-members-as-globals]
#                   [--rename-safe-only] [--reorder-safe-only] [--builtins-safe-only] [--rename-map RENAME_MAP] [--const NAME VALUE] [--str-const NAME VALUE] [-l] [--no-lint-unused]
#                   [--no-lint-unused-global] [--no-lint-duplicate] [--no-lint-duplicate-global] [--no-lint-undefined] [--no-lint-fail] [--lint-global LINT_GLOBAL]
#                  [--error-format ERROR_FORMAT] [-c] [--input-count] [--parsable-count] [--no-count-compress] [--no-count-tokenize] [-U] [--unminify-indent UNMINIFY_INDENT] [-s SCRIPT]
#                   [--script-args ...] [--label LABEL] [--title TITLE] [--extra-output OUTPUT [FORMAT] [...]] [--merge INPUT SECTIONS [FORMAT] [...]] [--list] [--dump DUMP]
#                   [--cart CART] [--pico8-dat PICO_DAT] [--output-cart OUTPUT_CART] [--extra-input INPUT [FORMAT [NAME]] [...]] [--template-image TEMPLATE_IMAGE] [--template-only]
#                   [--version] [--output-version OUTPUT_VERSION] [--update-version] [--bbs] [--url] [--dump-misc-too] [--insert-cart [NAME [BEFORE ...]]] [--replace-cart [NAME ...]]
#                   [--delete-cart DELETE_CART] [--rename-cart OLD NEW] [--keep-compression] [--force-compression] [--old-compression] [--optimize-png-compression] [--fast-compression]
#                   [--trace-compression TRACE_COMPRESSION] [--trace-input-compression TRACE_INPUT_COMPRESSION] [--ignore-hints] [--builtin BUILTIN] [--not-builtin NOT_BUILTIN]
#                   [--export-name EXPORT_NAME] [--clean-output-dir] [--global-builtins-only] [--local-builtin LOCAL_BUILTIN] [--output-sections OUTPUT_SECTIONS]
#                   [input] [additional_inputs ...] [output]

MINIFY_OPTS="--no-minify-rename --no-minify-spaces"
